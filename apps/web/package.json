    "zustand": "^4.3.0",
    "react-native-gesture-handler": "^2.12.0",
    "expo-speech": "^11.4.0",
    "axios": "^1.4.0"
  },
  "devDependencies": {
    "@types/react": "^18.0.0",
    "@types/react-native": "^0.71.0",
    "typescript": "^5.0.0",
    "eslint": "^8.0.0",
    "prettier": "^3.0.0"
  }
}
